{
  "name": "agent-arena",
  "version": "1.0.0",
  "description": "Spawn multiple AI agents in parallel to build competing implementations",
  "type": "module",
  "bin": {
    "arena": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["ai", "agents", "arena", "copilot", "claude", "cli"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "strip-ansi": "^7.1.0",
    "tree-kill": "^1.2.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "eslint": "^9.19.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
