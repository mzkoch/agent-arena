{
  "name": "agent-arena",
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform CLI for running competing autonomous coding agents in isolated git worktrees.",
  "bin": {
    "arena": "bin/arena.cjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md",
    "DESIGN.md",
    "Formula",
    "scripts",
    "Dockerfile"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run lint && npm run build && npm run test:coverage",
    "package:binaries": "npm run build && npx @yao-pkg/pkg dist/cli.js --targets node20-linux-x64,node20-linux-arm64,node20-macos-x64,node20-macos-arm64,node20-win-x64 --out-path release"
  },
  "pkg": {
    "assets": [
      "node_modules/node-pty/build/Release/*.node"
    ],
    "outputPath": "release"
  },
  "keywords": [
    "cli",
    "ink",
    "pty",
    "git-worktree",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "ink": "^5.2.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "strip-ansi": "^7.1.0",
    "zod": "^4.1.5"
  },
  "overrides": {
    "test-exclude": {
      "glob": "^13.0.0"
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.23",
    "@types/react-test-renderer": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "react-test-renderer": "^18.3.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
